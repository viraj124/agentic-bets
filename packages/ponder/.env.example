# RPC URL for Base mainnet (chain 8453).
# Ponder uses this for historical event sync + live indexing.
# A public RPC works for testing; use a paid provider for production reliability.
PONDER_RPC_URL=https://base-rpc.publicnode.com

# Optional: paid RPC for faster historical sync (< 1 min vs ~5 min with public)
# PONDER_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Port Ponder listens on (default 42069). Change if needed.
# PORT=42069
