# Template for NextJS environment variables.
#
# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, store vars in Vercel / system config.

# To access values stored here: process.env.VARIABLENAME
# Prefix with NEXT_PUBLIC_ to expose on the client side.
# More info: https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables

# ── RPC / Wallet ──────────────────────────────────────────────────────
# Alchemy key for ENS resolution and the built-in RPC proxy (/api/rpc/*)
ALCHEMY_API_KEY=
# Optional: explicit Ethereum mainnet RPC for ENS/WeiName resolution
# If not set, ALCHEMY_API_KEY is used automatically
MAINNET_RPC_URL=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ── Price feeds ───────────────────────────────────────────────────────
# Optional: 0x API key for live price fallback (/api/live-price)
# Used with 0x Swap API v2 allowance-holder/price endpoint.
0X_API_KEY=
# Optional: Uniswap Trading API key for live price fallback (/api/live-price)
# Get one free at https://developers.uniswap.org/dashboard/
UNISWAP_API_KEY=

# ── Ponder indexer ────────────────────────────────────────────────────
# URL of the running Ponder service (packages/ponder/).
# Local dev:   http://localhost:42069  (run `cd packages/ponder && npm run dev`)
# Production:  https://<your-service>.railway.app
PONDER_URL=http://localhost:42069

# ── Referral persistence ──────────────────────────────────────────────
# Optional locally. Required in production if referrals should survive
# deploys, cold starts, and serverless instance changes.
# Vercel Marketplace Redis / Upstash usually provides one of these pairs.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative Upstash naming also works:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
