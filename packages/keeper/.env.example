# Required
KEEPER_PRIVATE_KEY=0x...           # Hex private key for the keeper wallet (gas ETH only)
RPC_URL=https://...                # Base mainnet RPC (Alchemy/QuickNode recommended)
SWEEP_RECIPIENT=0x...              # Address to sweep accumulated USDC fees to

# Optional
POLL_INTERVAL_MS=10000             # Poll frequency in ms (default: 10000)
PORT=3000                          # Health server port (default: 3000)
SWEEP_THRESHOLD_USDC=10            # Min USDC balance to trigger sweep (default: 10)
SWEEP_INTERVAL_TICKS=60            # Sweep check frequency in ticks (default: 60)
MIN_ETH_BALANCE=0.005              # Low ETH balance warning threshold (default: 0.005)
